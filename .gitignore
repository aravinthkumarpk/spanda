# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/work/perf-baselines/

# test-doctor-stream.sh artifacts
/.test-doctor/

# test-plans-live.sh artifacts
/.test-plans-live/

# test-cli-approvals-manual.sh artifacts
/.test-cli-approvals-manual/
/.approval-validation/

# build-cli.sh local state
/.local-state/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# committed deploy defaults — no secrets, just surface narrowing (MVP)
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# claude code
.claude/*
!.claude/skills/
!.claude/skills/**

# interaction logs (dev mode)
.foolery-logs/

# playwright mcp
.playwright-mcp/

# local git worktrees
/.worktrees/

# knots local store
/.knots/

# settings files (may contain API keys)
settings.toml
qa-screenshots/

/.agents/*
!/.agents/skills/
!/.agents/skills/**
.gstack/

# build output + editor backups (added during cleanup)
dist-rebrand/
*.bak-*
